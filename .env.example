APP_NAME=ResumAi API
APP_ENV=development

DATABASE_URL=postgresql+psycopg://resumai:resumai_password@postgres:5432/resumai

JWT_SECRET=change_this_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50
MAX_LLM_CHARS=30000
SUMMARY_CHUNK_CHARS=12000
SUMMARY_CHUNK_OVERLAP_CHARS=500
SUMMARY_MAX_CHUNKS=20
USER_MAX_ACTIVE_SUMMARY_JOBS=2
SUMMARY_MAX_ATTEMPTS=3

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

CELERY_BROKER_URL=amqp://resumai:resumai_password@rabbitmq:5672//
